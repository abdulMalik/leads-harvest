 {
    "manifest_version": 3,
    "name": "Leads Harvest — Local Business Leads",
    "version": "0.3.0",
    "description": "Extract local business contact data from Google Maps for sales prospecting and outreach.",
    "permissions": ["storage", "scripting", "activeTab", "downloads", "tabs"],
    "host_permissions": ["https://www.google.com/maps/*", "<all_urls>"],
    "icons": {
      "16": "leads-harvest-16.png",
      "48": "leads-harvest-48.png",
      "128": "leads-harvest-128.png"
    },
    "action": {
      "default_popup": "popup.html",
      "default_title": "Leads Harvest",
      "default_icon": {
        "16": "leads-harvest-16.png",
        "48": "leads-harvest-48.png",
        "128": "leads-harvest-128.png"
      }
    },
    "background": {
      "service_worker": "background.js"
    },
    "content_scripts": [
      {
        "matches": ["https://www.google.com/maps/*"],
        "js": ["social_classifier.js", "content.js"],
        "run_at": "document_idle"
      }
    ]
  }
